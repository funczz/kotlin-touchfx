# Created by https://gitignore.org
# Gradle.gitignore

.gradle
**/build/
!**/src/**/build/

# Ignore Gradle GUI config
gradle-app.setting

# Avoid ignoring Gradle wrapper jar file (.jar files are usually ignored)
!gradle-wrapper.jar

# Avoid ignore Gradle wrappper properties
!gradle-wrapper.properties

# Cache of project
.gradletasknamecache

# Eclipse Gradle plugin generated files
# Eclipse Core
.project
# JDT-specific (Eclipse Java Development Tools)
.classpath

# generated code

# log
*.log
!**/src/**/*.log

# other
/gradle.properties
/local.properties
/.iml
/.idea/
/.externalNativeBuild
/captures/
/out/
/target/
/.kotlintest/
/local.*
.DS_Store
*.hprof

